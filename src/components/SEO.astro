---
import { baseDomain, structuredData } from '@/config/app'
import { appName } from '@/constants'
import { generateAlternateVersions } from '@/lib/alternateVersions'
import * as m from '@/paraglide/messages'
import { AstroFont } from 'astro-font'
import { join } from 'node:path'

const rawLocale = (Astro.locals.locale || 'en').toString().toLowerCase()

const {
  ldJSON = structuredData,
  title = m.website_title({}, { locale: Astro.locals.locale }),
  description = m.website_description({}, { locale: Astro.locals.locale }),
  url = Astro.url,
  image = `${Astro.locals.runtimeConfig.public.baseUrl}/capgo_banner.png`,
  canonical = Astro.url,
  author = `Martin DONADIEU`,
  keywords = m.website_keywords({}, { locale: Astro.locals.locale }),
  audio = null,
  alternateVersions = generateAlternateVersions(Astro),
  robots = 'index, follow',
} = Astro.props

const localeName_to_OGP = {
  en: 'en_US',
  de: 'de_DE',
  es: 'es_ES',
  fr: 'fr_FR',
  id: 'id_ID',
  it: 'it_IT',
  ja: 'ja_JP',
  ko: 'ko_KR',
  zh: 'zh_CN',
} as const

const localeOGP = localeName_to_OGP[rawLocale as keyof typeof localeName_to_OGP] ?? localeName_to_OGP.en

const toStringUrl = (value: unknown): string | null => {
  if (!value) return null
  if (typeof value === 'string') return value
  if (value instanceof URL) return value.toString()
  if (typeof (value as { toString?: () => string })?.toString === 'function') return (value as { toString: () => string }).toString()
  return null
}

const titleString = typeof title === 'string' && title.trim().length > 0 ? title : m.website_title({}, { locale: Astro.locals.locale })
const descriptionString = typeof description === 'string' && description.trim().length > 0 ? description : m.website_description({}, { locale: Astro.locals.locale })

const urlString = toStringUrl(url) || Astro.url.toString()
const canonicalString = toStringUrl(canonical) || urlString

const baseUrl = Astro.locals.runtimeConfig.public.baseUrl || Astro.url.origin
const rawImage = typeof image === 'string' ? image : toStringUrl(image)
const imageUrl = rawImage ? new URL(rawImage, baseUrl).toString() : new URL('/capgo_banner.png', baseUrl).toString()

let displayDescription = descriptionString
const descSize = 170
if (displayDescription.length > descSize) displayDescription = `${displayDescription.substring(0, descSize - 3)}...`

const image_unsecure = imageUrl.replace('https://', 'http://')
const titleFix = titleString || (imageUrl.split('/').pop() || '.').split('.')[0]

const makeFontPath = (name: string) => join(process.cwd(), 'public', 'fonts', name)
---

<AstroFont
  config={[
    {
      preload: false,
      display: 'swap',
      fallback: 'serif',
      selector: '.font-light',
      name: 'AirbnbCerealLight',
      src: [
        {
          style: 'light',
          weight: '300',
          path: makeFontPath('AirbnbCerealLight.woff'),
        },
      ],
    },
    {
      preload: false,
      display: 'swap',
      fallback: 'serif',
      selector: '.font-medium',
      name: 'AirbnbCerealMedium',
      src: [
        {
          style: 'medium',
          weight: '500',
          path: makeFontPath('AirbnbCerealMedium.woff'),
        },
      ],
    },
    {
      preload: true,
      display: 'swap',
      fallback: 'serif',
      selector: '.font-bold',
      name: 'AirbnbCerealBold',
      src: [
        {
          style: 'bold',
          weight: '800',
          path: makeFontPath('AirbnbCerealBold.woff'),
        },
      ],
    },
  ]}
/>

<!-- Sitemap -->
<link rel="sitemap" href="/sitemap-index.xml" />

<!-- Global Metadata -->
<meta charset="utf-8" />
<meta name="theme-color" content="#456b9a" />
<meta name="generator" content={Astro.generator} />
<meta http-equiv="X-UA-Compatible" content="IE=edge" />
<meta name="apple-mobile-web-app-title" content={baseDomain()} />
<meta name="viewport" content="width=device-width,initial-scale=1" />
<meta property="keywords" content={keywords} />

<link rel="canonical" href={canonicalString} />
<link rel="apple-touch-icon" href="/capgo.webp" />
<link rel="icon" href="/favicon.ico" sizes="any" />
<link rel="icon" type="image/png" href="/favicon.png" />
<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
<link rel="mask-icon" href="/safari-pinned-tab.svg" color="#00aba9" />

<!-- Hreflang tags for internationalization -->
{
  alternateVersions &&
    alternateVersions.length > 0 &&
    alternateVersions.map((version: { locale: string; url: string }) => <link rel="alternate" hreflang={version.locale} href={version.url} />)
}
{
  alternateVersions && alternateVersions.length > 0 && (
    <link rel="alternate" hreflang="x-default" href={alternateVersions.find((v: { locale: string }) => v.locale === 'en')?.url || alternateVersions[0].url} />
  )
}

<!-- Primary Meta Tags -->
<title set:html={titleString} />
<meta name="title" content={titleString} />
<meta name="author" content={author} />
<meta name="description" content={displayDescription} />
<meta name="robots" content={robots} />

<!-- Open Graph / Facebook -->
<meta property="og:url" content={urlString} />
<meta property="og:title" content={titleString} />
<meta property="og:audio" content={audio} />
<meta property="og:type" content="website" />
<meta property="og:locale" content={localeOGP} />
<meta property="og:type" content="website" />
<meta property="og:image:width" content="1200" />
<meta property="og:image:height" content="627" />
<meta property="og:image:alt" content={titleFix} />
<meta property="og:image:secure" content={imageUrl} />
<meta property="og:image" content={image_unsecure} />
<meta property="og:image:type" content="image/webp" />
<meta property="og:article:author" content={author} />
<meta property="og:audio:type" content="audio/mpeg" />
<meta property="og:site_name" content={baseDomain()} />
<meta property="og:description" content={displayDescription} />

<!-- Twitter -->
<meta property="twitter:url" content={urlString} />
<meta property="twitter:title" content={titleString} />
<meta property="twitter:image" content={imageUrl} />
<meta property="twitter:app:id:iphone" content={appName} />
<meta property="twitter:app:name:iphone" content="1602316563" />
<meta property="twitter:creator" content="@martindonadieu" />
<meta property="twitter:card" content="summary_large_image" />
<meta property="twitter:description" content={displayDescription} />
<meta property="twitter:app:id:googleplay" content="ee.forgr.capgo" />
<meta property="twitter:app:name:googleplay" content={appName} />

<!-- @ts-ignore -->
<script is:inline hid="seo-schema-graph" type="application/ld+json" set:html={JSON.stringify(ldJSON)} />

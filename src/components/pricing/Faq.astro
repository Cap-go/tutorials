---
import { getRelativeLocaleUrl } from 'astro:i18n'
import I18nText from '@/components/I18nText.astro'
---

<section class="bg-gray-900 py-10 sm:py-16 lg:py-24">
  <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-2xl text-center">
      <h2 class="text-3xl leading-tight font-bold text-white sm:text-4xl lg:text-5xl">
        <I18nText k="questions_and_answers" />
      </h2>
      <p class="mx-auto mt-4 max-w-xl text-base leading-relaxed text-gray-300">
        <I18nText k="explore_common_questions" />
      </p>
    </div>
    <div class="mt-12 grid grid-cols-1 gap-x-20 gap-y-16 md:mt-20 md:grid-cols-2">
      <div class="flex items-start">
        <div class="flex h-8 w-8 shrink-0 items-center justify-center rounded-full bg-gray-700">
          <span class="text-lg font-semibold text-white">?</span>
        </div>
        <div class="ml-4">
          <p class="text-xl font-semibold text-white"><I18nText k="how_are_mau_counted" /></p>
          <p class="mt-4 text-base text-gray-400">
            <I18nText k="mau_counting_explanation" />
          </p>
          <p class="mt-4 text-base text-gray-400">
            <I18nText k="capgo_usage_explanation" />
            <a class="border-b-2 border-blue-600 hover:text-blue-600 focus:text-blue-600" href={getRelativeLocaleUrl(Astro.locals.locale, 'blog/how-your-usage-is-counted')}>
              <I18nText k="here" />
            </a>
          </p>
        </div>
      </div>
      <div class="flex items-start">
        <div class="flex h-8 w-8 shrink-0 items-center justify-center rounded-full bg-gray-700">
          <span class="text-lg font-semibold text-white">?</span>
        </div>
        <div class="ml-4">
          <p class="text-xl font-semibold text-white"><I18nText k="what_does_storage_mean" /></p>
          <p class="mt-4 text-base text-gray-400">
            <I18nText k="storage_explanation" />
          </p>
        </div>
      </div>
      <div class="flex items-start">
        <div class="flex h-8 w-8 shrink-0 items-center justify-center rounded-full bg-gray-700">
          <span class="text-lg font-semibold text-white">?</span>
        </div>
        <div class="ml-4">
          <p class="text-xl font-semibold text-white"><I18nText k="how_is_bandwidth_counted" /></p>
          <p class="mt-4 text-base text-gray-400">
            <I18nText k="bandwidth_explanation" />
          </p>
        </div>
      </div>
      <div class="flex items-start">
        <div class="flex h-8 w-8 shrink-0 items-center justify-center rounded-full bg-gray-700">
          <span class="text-lg font-semibold text-white">?</span>
        </div>
        <div class="ml-4">
          <p class="text-xl font-semibold text-white"><I18nText k="unsure_about_active_users" /></p>
          <p class="mt-4 text-base text-gray-400">
            <I18nText k="free_trial_explanation" />
          </p>
        </div>
      </div>
    </div>
    <div class="mt-12 flex items-center justify-center md:mt-20">
      <div class="rounded-full bg-gray-800 px-8 py-4 text-center">
        <p class="text-gray-50">
          <I18nText k="didnt_find_answer" />
          <a class="text-yellow-300 transition-all duration-200 hover:text-yellow-400 hover:underline focus:text-yellow-400" href="mailto:support@capgo.app">
            <I18nText k="contact_support" />
          </a>
        </p>
      </div>
    </div>
  </div>
</section>
